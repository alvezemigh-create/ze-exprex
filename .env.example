# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Site ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Gateway de pagamento PIX ===
# Voce pode ter os DOIS configurados ao mesmo tempo. O gateway ativo e
# escolhido no painel admin em /admin/pagamento (salvo na tabela app_config).

# --- OneTimePay ---
# Pegue em: https://app.onetimepay.com.br/painel (Configuracoes > API)
# Webhook (cadastre no painel deles): https://SEU_SITE/api/pagamento/webhook
ONETIMEPAY_PUBLIC_KEY=pub_xxx
ONETIMEPAY_SECRET_KEY=sec_xxx
# (opcional, default: https://app.onetimepay.com.br/api/v1)
# ONETIMEPAY_API_URL=

# --- MarchaBB ---
# Pegue em: https://app.marchabb.com/integrations
# Doc: https://app.marchabb.com/docs/intro/first-steps
# Webhook (cadastre no painel deles): https://SEU_SITE/api/pagamento/webhook/marchabb
MARCHABB_PUBLIC_KEY=pk_xxx
MARCHABB_SECRET_KEY=sk_xxx
# (opcional, default: https://api.marchabb.com/v1)
# MARCHABB_API_URL=

# --- CenturionPay ---
# Pegue em: painel CenturionPay > Integrações > Chaves de API
# Doc: https://centurion.readme.io/
# Webhook (cadastre no painel deles): https://SEU_SITE/api/pagamento/webhook/centurionpay
CENTURIONPAY_SECRET_KEY=sk_live_xxx
CENTURIONPAY_COMPANY_ID=00000000-0000-0000-0000-000000000000
# (opcional, default: https://api.centurionpay.com.br/functions/v1)
# CENTURIONPAY_API_URL=
